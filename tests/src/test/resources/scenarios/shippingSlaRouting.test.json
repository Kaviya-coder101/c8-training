    {
      "name": "Unknown zone priority order — no rule matches (UK stress test)",
      "description": "A priority order to an out-of-range zone (UK) matches no rule; the UNIQUE table returns no result rather than a safe default.",
      "instructions": [
        {
          "type": "EVALUATE_DECISION",
          "decisionDefinitionSelector": { "decisionDefinitionId": "shippingSlaRouting" },
