{
  "$schema": "https://camunda.com/json-schema/cpt-test-cases/8.9/schema.json",
  "testCases": [
    {
      "name": "Domestic priority order — EXPRESS in 1 day (rule 1)",
      "description": "A priority order shipping domestically routes to EXPRESS with the tightest SLA.",
      "instructions": [
        {
          "type": "EVALUATE_DECISION",
          "decisionDefinitionSelector": { "decisionDefinitionId": "shippingSlaRouting" },
          "variables": { "destinationZone": "DOMESTIC", "priority": true }
        },
        {
          "type": "ASSERT_DECISION",
          "decisionSelector": { "decisionDefinitionId": "shippingSlaRouting" },
          "output": { "shippingMethod": "EXPRESS", "slaDays": 1 },
          "matchedRules": [1]
        }
      ]
    },
    {
      "name": "Domestic standard order — STANDARD in 3 days (rule 2)",
      "description": "A non-priority order shipping domestically routes to STANDARD.",
      "instructions": [
        {
          "type": "EVALUATE_DECISION",
          "decisionDefinitionSelector": { "decisionDefinitionId": "shippingSlaRouting" },
          "variables": { "destinationZone": "DOMESTIC", "priority": false }
        },
        {
          "type": "ASSERT_DECISION",
          "decisionSelector": { "decisionDefinitionId": "shippingSlaRouting" },
          "output": { "shippingMethod": "STANDARD", "slaDays": 3 },
          "matchedRules": [2]
        }
      ]
    },
    {
