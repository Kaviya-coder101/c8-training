# Copy this file to .env and fill in the values (.env is git-ignored).
#
# Local c8run cluster: only CAMUNDA_BASE_URL is needed (no auth).
#   CAMUNDA_BASE_URL=http://localhost:8080
#
# Camunda 8 SaaS / Self-Managed: provide the OAuth client credentials below.
# These are the same CAMUNDA_* variables that c8ctl and the Java client read.

CAMUNDA_BASE_URL=http://localhost:8080

# --- Required for SaaS / Self-Managed (OAuth) ---
# CAMUNDA_OAUTH_URL=
# CAMUNDA_CLIENT_ID=
# CAMUNDA_CLIENT_SECRET=
# CAMUNDA_TOKEN_AUDIENCE=
