# Copy this file to .env and fill in the values (.env is git-ignored).
# These are the CAMUNDA_* variables read by @camunda8/orchestration-cluster-api.
#
# --- Local c8run cluster (no auth) ---
CAMUNDA_REST_ADDRESS=http://localhost:8080/v2
CAMUNDA_AUTH_STRATEGY=NONE

# --- Camunda 8 SaaS / Self-Managed (OAuth) ---
# Set CAMUNDA_AUTH_STRATEGY=OAUTH and fill in the rest:
# CAMUNDA_REST_ADDRESS=https://<region>.zeebe.camunda.io/<cluster-id>
# CAMUNDA_AUTH_STRATEGY=OAUTH
# CAMUNDA_OAUTH_URL=
# CAMUNDA_CLIENT_ID=
# CAMUNDA_CLIENT_SECRET=
# CAMUNDA_TOKEN_AUDIENCE=zeebe.camunda.io
