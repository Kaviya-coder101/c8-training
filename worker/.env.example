# Camunda 8.9 SaaS connection for the job workers.
#
# Copy to `worker/.env` (git-ignored) and fill in real values. The SDK's
# createCamundaClient() reads these automatically — nothing is hard-coded.
#
# Rotate the client secret in the Camunda Console if it is ever pasted into a
# terminal, chat, or transcript.

# REST base URL of your cluster + the /v2 API prefix, e.g.
# https://<region>.api.camunda.io/<clusterId>/v2
CAMUNDA_REST_ADDRESS=

# OAuth (client credentials) — the SaaS default.
CAMUNDA_AUTH_STRATEGY=OAUTH
CAMUNDA_CLIENT_ID=
CAMUNDA_CLIENT_SECRET=
CAMUNDA_OAUTH_URL=https://login.cloud.camunda.io/oauth/token
CAMUNDA_TOKEN_AUDIENCE=zeebe.camunda.io
