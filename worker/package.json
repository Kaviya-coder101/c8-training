{
  "name": "kaviya-order-process-worker",
  "version": "1.0.0",
  "description": "TypeScript job worker skeleton for the kaviya_order_process (Camunda 8.9) BPMN process",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@camunda8/orchestration-cluster-api": "^9.1.2",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0"
  }
}
