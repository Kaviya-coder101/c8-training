{
  "name": "kaviya-order-process-worker",
  "version": "1.0.0",
  "private": true,
  "description": "TypeScript job workers for the kaviya_order_process Camunda 8.9 process",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "node --experimental-strip-types --watch src/index.ts"
  },
  "dependencies": {
    "@camunda8/orchestration-cluster-api": "^9.1.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0"
  }
}
