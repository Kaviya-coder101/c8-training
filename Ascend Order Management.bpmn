  <bpmn:process id="ascend-po-update-kaviya" name="Ascend Order Management" isExecutable="true">
    <bpmn:startEvent id="Event_0bbjpjg" name="PO update requested">
      <bpmn:extensionElements>
        <zeebe:ioMapping>
          <zeebe:output source="=order_id" target="order_id" />
          <zeebe:output source="=requested_by" target="requested_by" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:outgoing>Flow_0notcm4</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDefinition_1csz97h" messageRef="Message_0cj3q13" />
    </bpmn:startEvent>
    <bpmn:serviceTask id="Activity_0sq4lp6" name="Query order information">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="query-order" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0notcm4</bpmn:incoming>
      <bpmn:outgoing>Flow_1tecgy7</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_0notcm4" sourceRef="Event_0bbjpjg" targetRef="Activity_0sq4lp6" />
    <bpmn:userTask id="Activity_06c0ynw" name="Review PO change">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:ioMapping>
          <zeebe:input source="=order_title" target="order_title" />
          <zeebe:input source="=order_status" target="order_status" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0sc8mo0</bpmn:incoming>
      <bpmn:outgoing>Flow_0cqsew0</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:sequenceFlow id="Flow_1tecgy7" sourceRef="Activity_0sq4lp6" targetRef="Gateway_1169v78" />
    <bpmn:exclusiveGateway id="Gateway_1169v78" name="Order found &#38; open?" default="Flow_0zk6nwr">
      <bpmn:incoming>Flow_1tecgy7</bpmn:incoming>
      <bpmn:outgoing>Flow_0sc8mo0</bpmn:outgoing>
      <bpmn:outgoing>Flow_0zk6nwr</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_0sc8mo0" sourceRef="Gateway_1169v78" targetRef="Activity_06c0ynw">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=order_status = "OPEN"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:endEvent id="Event_0hx606b" name="Change rejected">
      <bpmn:incoming>Flow_0zk6nwr</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_0zk6nwr" sourceRef="Gateway_1169v78" targetRef="Event_0hx606b" />
    <bpmn:exclusiveGateway id="Gateway_05fb2vs" name="What is the Order change type?" default="Flow_0bibq6w">
      <bpmn:incoming>Flow_0cqsew0</bpmn:incoming>
      <bpmn:outgoing>Flow_1e343no</bpmn:outgoing>
      <bpmn:outgoing>Flow_0bibq6w</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_0cqsew0" sourceRef="Activity_06c0ynw" targetRef="Gateway_05fb2vs" />
    <bpmn:sequenceFlow id="Flow_1e343no" sourceRef="Gateway_05fb2vs" targetRef="Event_007u5dz">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=checkbox_quantity_change != null and checkbox_quantity_change = true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:intermediateThrowEvent id="Event_007u5dz" name="Quantity change">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="quantity-change" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1e343no</bpmn:incoming>
      <bpmn:outgoing>Flow_0sasdkz</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDefinition_0wbak7v" />
    </bpmn:intermediateThrowEvent>
    <bpmn:sequenceFlow id="Flow_0bibq6w" sourceRef="Gateway_05fb2vs" targetRef="Event_09y1mn0" />
    <bpmn:intermediateThrowEvent id="Event_09y1mn0" name="Other Changes">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="other-changes" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0bibq6w</bpmn:incoming>
      <bpmn:outgoing>Flow_0wew88e</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDefinition_148fiji" />
    </bpmn:intermediateThrowEvent>
    <bpmn:exclusiveGateway id="Gateway_1bze9j4">
      <bpmn:incoming>Flow_0sasdkz</bpmn:incoming>
      <bpmn:incoming>Flow_0wew88e</bpmn:incoming>
      <bpmn:outgoing>Flow_15od6jo</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_0sasdkz" sourceRef="Event_007u5dz" targetRef="Gateway_1bze9j4" />
    <bpmn:sequenceFlow id="Flow_0wew88e" sourceRef="Event_09y1mn0" targetRef="Gateway_1bze9j4" />
    <bpmn:endEvent id="Event_1amav9m" name="PO Update Completed">
      <bpmn:incoming>Flow_15od6jo</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_15od6jo" sourceRef="Gateway_1bze9j4" targetRef="Event_1amav9m" />
  </bpmn:process>
